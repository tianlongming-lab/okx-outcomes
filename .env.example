# .env example for OKX Outcomes

# OKX API credentials
OKX_API_KEY=your_api_key
OKX_SECRET_KEY=your_secret_key
OKX_PASSPHRASE=your_passphrase

# Optional agent private key for EIP-712 signing (0x...)
OKX_AGENT_PRIVATE_KEY=your_agent_private_key

# Testnet flag
OKX_TESTNET=false

# Proxy for outgoing HTTP/WebSocket (optional)
OKX_PROXY=

# Chain id (optional)
OKX_CHAIN_ID=196
